# ===========================================
# CONFIGURAÇÃO DO WHATSAPP BUSINESS API (META)
# ===========================================

# Obtenha estas credenciais em: https://developers.facebook.com/apps
# Siga o guia completo em: WHATSAPP_SETUP_GUIDE.md

# ID do número de telefone do WhatsApp Business
# Encontre em: WhatsApp > Primeiros Passos > Phone Number ID
VITE_WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here

# ID da conta do WhatsApp Business (WABA)
# Encontre em: WhatsApp > Configurações > ID da conta
VITE_WHATSAPP_WABA_ID=your_waba_id_here

# Token de acesso da API
# Para produção, use um token de longa duração
# Gere em: Ferramentas > Graph API Explorer
VITE_WHATSAPP_ACCESS_TOKEN=your_access_token_here

# Versão da API do Graph (padrão: v19.0)
VITE_WHATSAPP_API_VERSION=v19.0

# ===========================================
# CONFIGURAÇÃO DO WEBHOOK
# ===========================================

# Token secreto para verificação do webhook
# Crie uma string aleatória e use a mesma na configuração do webhook na Meta
VITE_WEBHOOK_VERIFY_TOKEN=your_secret_verify_token_here

# Porta do servidor webhook (padrão: 3000)
VITE_WEBHOOK_PORT=3000

# ===========================================
# CREDENCIAIS DO APP META (OPCIONAL)
# ===========================================

# ID do aplicativo Meta
# Encontre em: Configurações > Básico
VITE_META_APP_ID=your_app_id_here

# Chave secreta do aplicativo (NÃO compartilhe!)
# Encontre em: Configurações > Básico
VITE_META_APP_SECRET=your_app_secret_here

# ===========================================
# FIREBASE (JÁ CONFIGURADO)
# ===========================================
# As configurações do Firebase já estão em src/config/firebase.js
# Se necessário, adicione suas credenciais aqui

# ===========================================
# GOOGLE GEMINI AI (OPCIONAL)
# ===========================================
# API Key do Google Gemini para funcionalidades de IA
# Obtenha em: https://makersuite.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here
